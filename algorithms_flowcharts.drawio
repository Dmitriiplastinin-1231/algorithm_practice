<mxfile host="Electron" modified="2024-01-01T12:00:00.000Z" agent="Mozilla/5.0" version="22.0.4" type="device">
  <diagram id="algorithms_diagram" name="ГА и PSO">
    <mxGraphModel dx="1400" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="2338" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ==================== ГЕНЕТИЧЕСКИЙ АЛГОРИТМ ==================== -->
        <mxCell id="ga_title" value="&lt;b&gt;Генетический алгоритм (ГА)&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="130" y="20" width="260" height="40" as="geometry" />
        </mxCell>

        <!-- Узлы ГА -->
        <mxCell id="ga_start" value="Начало" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="80" width="120" height="50" as="geometry" />
        </mxCell>

        <mxCell id="ga_input" value="Ввод параметров:&#10;размер популяции, P&#x2c;_скр, P&#x2c;_мут,&#10;кол-во поколений, элитизм" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="172" y="158" width="176" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ga_init" value="Создание начальной&#10;популяции (случайные&#10;бинарные хромосомы)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="185" y="248" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ga_eval1" value="Оценка приспособленности&#10;(вычисление f(x,y)&#10;для всех особей)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="185" y="340" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ga_loop_cond" value="Поколение &lt; MAX?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="195" y="430" width="130" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ga_select" value="Селекция: турнирный&#10;отбор родителей + элитизм&#10;(сохранение лучших)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="185" y="528" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ga_cross" value="Скрещивание&#10;(одноточечный кроссовер&#10;с вероятностью P_скр)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="185" y="620" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ga_mut" value="Мутация: инверсия бита&#10;(Bit-flip) с вероятностью&#10;P_мут для каждого бита" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="185" y="712" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ga_eval2" value="Оценка потомков:&#10;f(x,y) → приспособленность.&#10;Обновление популяции" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="185" y="806" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ga_stat" value="Сбор статистики:&#10;лучшее и среднее&#10;значения поколения" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="185" y="900" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ga_output" value="Вывод лучшего решения:&#10;(x*, y*, f*)" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="172" y="1010" width="176" height="55" as="geometry" />
        </mxCell>

        <mxCell id="ga_end" value="Конец" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="1095" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- Связи ГА -->
        <mxCell id="e_ga_1" edge="1" parent="1" source="ga_start" target="ga_input" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ga_2" edge="1" parent="1" source="ga_input" target="ga_init" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ga_3" edge="1" parent="1" source="ga_init" target="ga_eval1" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ga_4" edge="1" parent="1" source="ga_eval1" target="ga_loop_cond" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ga_5" edge="1" parent="1" source="ga_loop_cond" target="ga_select" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ga_5_label" value="Да" style="edgeLabel;html=1;align=left;verticalAlign=bottom;resizable=0;points=[];" vertex="1" connectable="0" parent="e_ga_5">
          <mxGeometry x="-0.7" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="e_ga_6" edge="1" parent="1" source="ga_select" target="ga_cross" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ga_7" edge="1" parent="1" source="ga_cross" target="ga_mut" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ga_8" edge="1" parent="1" source="ga_mut" target="ga_eval2" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ga_9" edge="1" parent="1" source="ga_eval2" target="ga_stat" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Возврат в цикл ГА -->
        <mxCell id="e_ga_back" edge="1" parent="1" source="ga_stat" target="ga_loop_cond" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="410" y="930" />
              <mxPoint x="410" y="460" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- Выход из цикла ГА (Нет) -->
        <mxCell id="e_ga_exit" edge="1" parent="1" source="ga_loop_cond" target="ga_output" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;exitDx=0;exitDy=0;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="100" y="460" />
              <mxPoint x="100" y="1037" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_ga_exit_label" value="Нет" style="edgeLabel;html=1;align=left;verticalAlign=bottom;resizable=0;points=[];" vertex="1" connectable="0" parent="e_ga_exit">
          <mxGeometry x="-0.7" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="e_ga_11" edge="1" parent="1" source="ga_output" target="ga_end" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== РОЕВОЙ АЛГОРИТМ (PSO) с коэффициентом сжатия ==================== -->
        <mxCell id="pso_title" value="&lt;b&gt;Роевой алгоритм (PSO) — с коэффициентом сжатия χ&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="640" y="20" width="360" height="40" as="geometry" />
        </mxCell>

        <!-- Узлы PSO -->
        <mxCell id="pso_start" value="Начало" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="760" y="80" width="120" height="50" as="geometry" />
        </mxCell>

        <mxCell id="pso_input" value="Ввод параметров:&#10;N частиц, T итераций,&#10;c₁, c₂, κ (каппа)" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="732" y="158" width="176" height="60" as="geometry" />
        </mxCell>

        <mxCell id="pso_chi_calc" value="Вычисление коэффициента&#10;сжатия χ:&#10;φ = c₁ + c₂ (&gt; 4)&#10;χ = 2κ / |2 − φ − √(φ²−4φ)|" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="732" y="248" width="176" height="75" as="geometry" />
        </mxCell>

        <mxCell id="pso_init" value="Инициализация роя:&#10;случайные позиции и&#10;скорости каждой частицы" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="745" y="355" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="pso_eval1" value="Первичная оценка f(x,y).&#10;Установка pbest_i = x_i,&#10;gbest = argmin f(x_i)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="745" y="447" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="pso_loop_cond" value="Итерация &lt; T?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="755" y="537" width="130" height="60" as="geometry" />
        </mxCell>

        <!-- Цикл по частицам -->
        <mxCell id="pso_particle_loop" value="Для каждой частицы i" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#f0f0f0;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="745" y="635" width="150" height="50" as="geometry" />
        </mxCell>

        <mxCell id="pso_vel" value="Обновление скорости&#10;с коэффициентом сжатия χ:&#10;v_i = χ·(v_i + c₁r₁(pbest_i − x_i)&#10;        + c₂r₂(gbest − x_i))" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="732" y="715" width="176" height="75" as="geometry" />
        </mxCell>

        <mxCell id="pso_pos" value="Обновление позиции:&#10;x_i = x_i + v_i" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="745" y="820" width="150" height="55" as="geometry" />
        </mxCell>

        <mxCell id="pso_bounds" value="Проверка границ:&#10;если x_i вне [-10,10] →&#10;обрезать + v_i *= −0.5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="745" y="907" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="pso_reeval" value="Переоценка: f(x_i).&#10;Обновить pbest_i&#10;и gbest при улучшении" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="745" y="1000" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="pso_stat" value="Сбор статистики:&#10;запись gbest и позиций&#10;всех частиц на итерации" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="745" y="1100" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="pso_output" value="Вывод лучшего решения:&#10;(x*, y*, f*)" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="732" y="1215" width="176" height="55" as="geometry" />
        </mxCell>

        <mxCell id="pso_end" value="Конец" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="760" y="1300" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- Связи PSO -->
        <mxCell id="e_pso_1" edge="1" parent="1" source="pso_start" target="pso_input" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_pso_2" edge="1" parent="1" source="pso_input" target="pso_chi_calc" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_pso_3" edge="1" parent="1" source="pso_chi_calc" target="pso_init" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_pso_4" edge="1" parent="1" source="pso_init" target="pso_eval1" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_pso_5" edge="1" parent="1" source="pso_eval1" target="pso_loop_cond" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_pso_6" edge="1" parent="1" source="pso_loop_cond" target="pso_particle_loop" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_pso_6_label" value="Да" style="edgeLabel;html=1;align=left;verticalAlign=bottom;resizable=0;points=[];" vertex="1" connectable="0" parent="e_pso_6">
          <mxGeometry x="-0.7" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="e_pso_7" edge="1" parent="1" source="pso_particle_loop" target="pso_vel" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_pso_8" edge="1" parent="1" source="pso_vel" target="pso_pos" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_pso_9" edge="1" parent="1" source="pso_pos" target="pso_bounds" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_pso_10" edge="1" parent="1" source="pso_bounds" target="pso_reeval" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_pso_11" edge="1" parent="1" source="pso_reeval" target="pso_stat" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Возврат в цикл PSO -->
        <mxCell id="e_pso_back" edge="1" parent="1" source="pso_stat" target="pso_loop_cond" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="980" y="1130" />
              <mxPoint x="980" y="567" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- Выход из цикла PSO (Нет) -->
        <mxCell id="e_pso_exit" edge="1" parent="1" source="pso_loop_cond" target="pso_output" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;exitDx=0;exitDy=0;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="660" y="567" />
              <mxPoint x="660" y="1242" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_pso_exit_label" value="Нет" style="edgeLabel;html=1;align=left;verticalAlign=bottom;resizable=0;points=[];" vertex="1" connectable="0" parent="e_pso_exit">
          <mxGeometry x="-0.7" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="e_pso_12" edge="1" parent="1" source="pso_output" target="pso_end" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Легенда / пояснение к χ -->
        <mxCell id="legend_chi" value="&lt;b&gt;Коэффициент сжатия χ:&lt;/b&gt;&#10;Обеспечивает гарантированную сходимость&#10;роя. При c₁ = c₂ = 2.05 (φ = 4.1, κ = 1):&#10;χ ≈ 0.7298. Частица «сжимает» скорость&#10;на каждой итерации, предотвращая расхождение." style="text;html=0;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1020" y="700" width="280" height="100" as="geometry" />
        </mxCell>

        <!-- Стрелка к легенде -->
        <mxCell id="e_legend" edge="1" parent="1" source="pso_vel" target="legend_chi" style="dashed=1;endArrow=open;endFill=0;strokeColor=#9673a6;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
